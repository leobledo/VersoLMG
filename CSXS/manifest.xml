<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0" ExtensionBundleId="com.leobledo.verso.lmg" ExtensionBundleVersion="10.0.0" ExtensionBundleName="Verso LMG">
  <ExtensionList>
    <Extension Id="com.leobledo.verso.lmg.panel" Version="1.0.0"/>
