  <ExecutionEnvironment>
    <HostList>
      <Host Name="AEFT" Version="[15.0,99.9]"/>
      <Host Name="PPRO" Version="[15.0,99.9]"/>
    </HostList>
    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="7.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  <DispatchInfoList>
