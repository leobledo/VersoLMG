            <Allow>
              <Domain schema="https">lrclib.net</Domain>
              <Domain schema="https">*</Domain>
            </Allow>
          </NetworkAccess>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>Verso LMG</Menu>
          <Geometry>
            <Size>
              <Height>600</Height>
              <Width>900</Width>
            </Size>
            <MinSize>
              <Height>380</Height>
              <Width>480</Width>
            </MinSize>
